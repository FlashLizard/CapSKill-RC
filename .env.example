# Copy to .env.local and fill in only the provider values you need.
# Never commit .env.local or put a real key in a command recorded by shell history.

# Web server
SKILLSBENCH_RUNNER_PORT=5198

# BenchFlow/Claude Code evaluation defaults
BENCHFLOW_PROVIDER_BASE_URL=https://api.deepseek.com
BENCHFLOW_PROVIDER_MODEL=deepseek-v4-flash
BENCHFLOW_PROVIDER_TYPE=deepseek
BENCHFLOW_REASONING_EFFORT=low
DEEPSEEK_API_KEY=
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Offline SkillRCA defaults
OFFLINE_SKILL_RCA_BASE_URL=https://api.deepseek.com
OFFLINE_SKILL_RCA_MODEL=deepseek-v4-flash
OFFLINE_SKILL_RCA_API_KEY=
OFFLINE_SKILL_RCA_REASONING_EFFORT=low
